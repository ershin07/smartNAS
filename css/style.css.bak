/* ===== GLOBAL ===== */
body {
    margin: 0;
    padding: 0;
    background: #0d0d0d;
    color: #e6e6e6;
    font-family: "Segoe UI", Arial, sans-serif;
}

.container {
    width: 90%;
    max-width: 1000px;
    margin: 40px auto;
}

/* ===== HEADER ===== */
header {
    text-align: center;
    margin-bottom: 40px;
}

header h1 {
    margin: 0;
    font-size: 38px;
    font-weight: 700;
    color: #ffffff;
}

.subtitle {
    margin-top: 10px;
    color: #b3b3b3;
    font-size: 16px;
}

/* ===== CARD ===== */
.card {
    background: #1a1a1a;
    padding: 25px;
    margin-bottom: 28px;
    border-radius: 14px;
    box-shadow: 0 0 18px rgba(0,0,0,0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 25px rgba(0,0,0,0.6);
}

.card h2 {
    margin-top: 0;
    margin-bottom: 20px;
    font-size: 24px;
    font-weight: 600;
    color: #f2f2f2;
}

/* ===== ROWS & CONTROLS ===== */
.row {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid #333;
}

.row:last-child {
    border-bottom: none;
}

.label {
    color: #b3b3b3;
    font-size: 15px;
}

.value {
    font-weight: 600;
    font-size: 15px;
    color: #ffffff;
}

/* ===== NAVIGATION GROUP ===== */
.top-controls {
    display: flex;
    justify-content: flex-start; /* Aligned to left to match Dashboard button */
    padding: 15px 20px;
    margin-bottom: 20px;
}

.control-buttons {
    display: flex;
    gap: 15px;
    align-items: center;
    width: 100%;
}

.btn-nav {
    padding: 10px 20px;
    background: #00e0c6;
    color: #000;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    transition: 0.2s;
}

.btn-nav:hover {
    background: #fff;
    box-shadow: 0 0 10px rgba(0, 224, 198, 0.4);
}

/* New OMV Button Style */
.omv-btn {
    background: #262626;
    color: #ffffff;
    border: 1px solid #444;
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: 0.2s;
}

.omv-btn i {
    color: #00e0c6; /* Matches the theme teal */
    font-size: 14px;
}

.omv-btn:hover {
    background: #333;
    border-color: #fff;
    color: #00e0c6;
}

/* Hamburger Fix */
.icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: auto; /* Pushes the menu icon to the far right */
}

.hamburger,
.hamburger::before,
.hamburger::after {
    width: 24px;
    height: 3px;
    background: #00e0c6;
    display: block;
    border-radius: 2px;
    transition: 0.2s;
    position: relative;
}

.hamburger::before, .hamburger::after {
    content: "";
    position: absolute;
    left: 0;
}
.hamburger::before { top: -7px; }
.hamburger::after { top: 7px; }

/* ===== UTILITIES ===== */
.value.present { color: #4caf50; }
.value.missing { color: #ff5252; }
.value.ip { white-space: pre-line; line-height: 1.4; }

/* ===== CARD GROUP LAYOUT ===== */
.card-group {
    display: flex;
    flex-direction: row;
    gap: 20px;
    align-items: stretch;
    margin-bottom: 28px;
    width: 100%;
}

.card-group .card {
    flex: 1;
    margin-bottom: 0 !important;
    min-width: 0;
}

@media (max-width: 900px) {
    .card-group {
        flex-direction: column;
    }
}